{
  "expo": {
    "name": "Enkap ERP",
    "slug": "enkap-erp",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "enkap",
    "jsEngine": "hermes",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Barkod tarama ve fiş okuma için kameraya erişim gereklidir."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.enkap.erp",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Güvenli giriş için Face ID kullanılır."
      }
    },
    "android": {
      "package": "com.enkap.erp",
      "adaptiveIcon": {
        "backgroundColor": "#1E3A5F"
      }
    },
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}
